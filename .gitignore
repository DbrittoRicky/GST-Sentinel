# ============================================================
# SECRETS & CREDENTIALS — Never commit these
# ============================================================
.env
.env.*
*.credentials
~/.copernicusmarine/

# ============================================================
# LARGE DATA FILES — Download locally, never commit
# ============================================================
data/raw/
data/processed/
*.nc
*.zarr/
*.npy
*.npz
*.pt
*.pth

# ============================================================
# PYTHON CACHE & BYTECODE
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# ============================================================
# JUPYTER NOTEBOOKS — checkpoints
# ============================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================
# CONDA / VIRTUAL ENVIRONMENTS — never commit env folders
# ============================================================
envs/
.venv/
venv/
env/

# ============================================================
# LOGS & TEMPORARY FILES
# ============================================================
*.log
logfile
pgdata/
*.tmp
*.temp

# ============================================================
# WINDOWS OS JUNK
# ============================================================
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# IDE FILES
# ============================================================
.vscode/
.idea/
*.sublime-workspace

# ============================================================
# BUILD & DIST
# ============================================================
dist/
build/
*.egg-info/

~/
pgdata/
